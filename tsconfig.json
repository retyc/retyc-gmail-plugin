{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "jsx": "preserve",
    "types": [
      "chrome",
      "vite/client"
    ],
    "paths": {
      "@iframe/*": [
        "./src/iframe/*"
      ],
      "@bridge/*": [
        "./src/shared/bridge/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "src/iframe/env.d.ts",
    "auto-imports.d.ts",
    "components.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
