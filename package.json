{
  "name": "retyc-gmail-plugin",
  "version": "0.0.1",
  "private": true,
  "description": "Gmail extension for Retyc — secure, end-to-end encrypted file transfers",
  "author": "TripleStack SAS",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/retyc/retyc-gmail-plugin.git"
  },
  "homepage": "https://retyc.com",
  "bugs": {
    "url": "https://github.com/retyc/retyc-gmail-plugin/issues"
  },
  "keywords": [
    "gmail",
    "webextension",
    "chrome-extension",
    "firefox-extension",
    "retyc",
    "file-transfer",
    "encryption",
    "e2e"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "watch": "vite build --watch --mode development",
    "lint": "eslint src",
    "typecheck": "vue-tsc --noEmit",
    "start": "vite --mode development",
    "package": "node scripts/package-zip.js",
    "lint:firefox": "web-ext lint --source-dir dist/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@inboxsdk/core": "^2.2.12",
    "@nuxt/ui": "^4.7.1",
    "@retyc/sdk": "^1.0.3",
    "dompurify": "^3.4.2",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.2",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@eslint/js": "^10.0.1",
    "@iconify-json/lucide": "^1.2.106",
    "@iconify/types": "^2.0.0",
    "@iconify/utils": "^3.1.3",
    "@types/chrome": "^0.1.42",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.6.2",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-vue": "^6.0.6",
    "buffer": "^6.0.3",
    "eslint": "^10.3.0",
    "path-browserify": "^1.0.1",
    "stream-browserify": "^3.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vue-tsc": "^3.2.8",
    "web-ext": "^10.1.0"
  }
}
